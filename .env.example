# Required for the app and the executable scripts in `scripts/`
# APP_MODE controls which database URL is used:
# - standalone: use DATABASE_URL
# - integrated: use NNRXOS_DATABASE_URL
# - auto: prefer NNRXOS_DATABASE_URL, otherwise use DATABASE_URL
APP_MODE=auto
DATABASE_URL=postgresql://user:password@host/database?sslmode=require
NNRXOS_DATABASE_URL=
NEXT_PUBLIC_DEMO_MODE=true
